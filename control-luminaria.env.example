# ============================================================================
# control-luminaria · Variables de entorno (Vercel · Production)
# Esquema ESCALABLE a varios paneles.
# Subida masiva: Settings → Environment Variables → pegar/importar un .env
# (los nombres NO se pueden repetir dentro de un mismo Environment).
# ============================================================================

# --- Códigos de acceso ---
# Código base de control (login; da acceso a lo normal: nodos, on/off, dim).
APP_ACCESS_CODE=tu_codigo_de_acceso
# Códigos por acción (ESCALABLE): APP_CODE_<ACCION> protege esa acción con un
# código aparte. Para proteger una acción nueva, crea su variable; sin tocar código.
APP_CODE_REBOOT=tu_codigo_de_reinicio
# Ejemplos a futuro:
# APP_CODE_FIRMWARE=...
# APP_CODE_MASS=...

# --- Registro de paneles (JSON, SIN secretos) ---
# Una sola variable lista qué paneles existen y sus subpaneles.
# El front la usa para poblar el selector de panel y subpanel.
UBI_PANELS=[{"id":"1494","name":"Default · Tele gestión MED","subpanels":["437","930","912"]},{"id":"803956","name":"Sales-Latam","subpanels":["1007"]}]

# --- Credenciales POR panel (cada panel tiene su propio client_id/secret) ---
# Convención compartida con la función de descarga de datos:
#   UBICQUIA_<panelId>_CLIENT_ID  /  UBICQUIA_<panelId>_CLIENT_SECRET
UBICQUIA_1494_CLIENT_ID=1494.ebustos_superuser@ubicquia.com
UBICQUIA_1494_CLIENT_SECRET=__secret_1494__
UBICQUIA_803956_CLIENT_ID=803956.ebustos_superuser@ubicquia.com
UBICQUIA_803956_CLIENT_SECRET=__secret_803956__

# (Ya existentes para la app de datos; reutilizables si los agregas a UBI_PANELS)
# UBICQUIA_565405_CLIENT_ID=...
# UBICQUIA_565405_CLIENT_SECRET=...
# UBICQUIA_646703_CLIENT_ID=...
# UBICQUIA_646703_CLIENT_SECRET=...

# --- Endpoints / ajustes (con default; normalmente no hace falta tocarlos) ---
# UBI_API_BASE=https://api.ubicquia.com/api
# UBI_AUTH_URL=https://auth.ubihub.ubicquia.com/auth/realms/ubivu-prd/protocol/openid-connect/token
# UBI_NODE_LEVEL_TYPE_ID=1
# UBI_DIM_TYPE=string
# UBI_REBOOT_MAX=5            # tope duro de dispositivos por reinicio (restartNode)
# UBI_BATCH_SIZE=250
# UBI_NODES_PER_PAGE=250
# UBI_NODES_MAX_PAGES=40
# UBI_NODES_TTL_MS=300000
# UBI_STATES_MAX=80
# UBI_STATES_CONCURRENCY=6

# ============================================================================
# YA NO SE USAN (las reemplaza UBI_PANELS + credenciales por panel) — eliminar:
#   UBI_PANEL_ID  ·  UBI_SUBPANEL_ID  ·  UBI_ALLOWED_SUBPANELS  ·  UBI_ALLOWED_IDS
# (El backend mantiene compatibilidad temporal: si NO defines UBI_PANELS, arma
#  un registro de 1 panel desde UBI_PANEL_ID + UBI_ALLOWED_SUBPANELS +
#  UBI_CLIENT_ID/UBI_CLIENT_SECRET. Migrar a UBI_PANELS cuando puedas.)
# ============================================================================
