# ============================================================================
# optimo-SEN · Variables de entorno (Vercel · Production)
# Analizador de desviación del óptimo operacional por restricciones ambientales.
# Mismo esquema del resto de griddata.cl: secretos SOLO en el server, el front
# manda el código en x-access-code.
# ============================================================================

# --- Conector IA (api/sen-clasifica.js) ---
# Clave de Anthropic. YA EXISTE en el proyecto (la usa también resumen-ia y bill);
# se REUTILIZA, no la dupliques.
# ANTHROPIC_API_KEY=sk-ant-...

# Código de acceso del ámbito SEN (gate de sen-clasifica y sen-sip).
# Convención APP_CODE_<NOMBRE> del sitio; aquí su variable propia:
SEN_ACCESS_CODE=tu_codigo_optimo_sen

# Opcional: override del modelo (default claude-sonnet-4-6, igual que el resto)
# IA_MODEL=claude-sonnet-4-6

# --- Conector de datos SIP (api/sen-sip.js) ---
# Clave de la API Pública del Coordinador. Regístrate en
# https://portal.api.coordinador.cl/ y crea la clave en https://sipub.coordinador.cl/
SIP_USER_KEY=__sip_user_key__

# Opcional: recurso/versión por defecto (dependen del plan al que te suscribas).
# Se pueden sobreescribir desde el front en la pestaña "Datos & conector".
# SIP_RECURSO=costo-marginal-real
# SIP_VERSION=v4

# ============================================================================
# Subida masiva: Settings → Environment Variables → pegar este .env
# (recuerda: los nombres NO se repiten dentro de un mismo Environment;
#  ANTHROPIC_API_KEY ya debería estar — no la agregues dos veces)
# ============================================================================
