# ============================================================================
# optimo-SEN · Variables de entorno (Vercel · Production)
# Plataforma de cara al cliente: el front NO pide código. Las claves viven solo
# en las funciones serverless y el acceso se restringe por ORIGEN (dominio).
# ============================================================================

# --- IA (api/sen-clasifica.js) ---
# Clave de Anthropic. YA EXISTE en el proyecto (resumen-ia, bill); se REUTILIZA.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Datos SIP (api/sen-sip.js) · modo público (user_key) ---
# user_key del plan "Información Pública (SIP)" (estado Activo).
SIP_USER_KEY=__sip_user_key__

# --- Protección por origen (recomendado) ---
# Orígenes permitidos a llamar /api/sen-*. Si lo dejas vacío, queda abierto.
SEN_ALLOWED_ORIGINS=https://griddata.cl,https://www.griddata.cl

# --- Opcionales ---
# IA_MODEL=claude-sonnet-4-6
# SIP_RECURSO=costo-marginal-real
# SIP_VERSION=v4
# SIP_METODO=findByDate

# --- Datos SIP · modo operacional (OAuth, planes "Pendiente") — opcional ---
# SIP_CLIENT_ID=__client_id__
# SIP_CLIENT_SECRET=__client_secret__
# SIP_OP_BASE=https://mercados.api.coordinador.cl

# ============================================================================
# Nota: Origin/Referer es falsificable por clientes que no son navegadores.
# Para blindaje fuerte de la clave, suma rate-limit (Vercel WAF) a /api/sen-*.
# ============================================================================
